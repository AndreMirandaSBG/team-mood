rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── moods ──────────────────────────────────────────────────────────────
    // Each doc ID is "{weekKey}_{uidHash}" (e.g. "2026-W10_a3f9...")
    // - Anyone authenticated (anonymous) can create their own entry
    // - No one can read individual mood entries (only Cloud Functions can)
    // - No one can update or delete (immutable once submitted)
    match /moods/{docId} {
      allow create: if
        request.auth != null &&
        request.resource.data.keys().hasAll(['weekKey', 'score', 'submittedAt', 'uidHash']) &&
        request.resource.data.score is int &&
        request.resource.data.score >= 1 &&
        request.resource.data.score <= 10 &&
        request.resource.data.weekKey is string &&
        request.resource.data.weekKey.matches('^[0-9]{4}-W[0-9]{2}$');

      // Allow the user to read their own entry (to check if they already submitted)
      allow get: if
        request.auth != null;

      // Deny list, update, delete — prevent enumeration and tampering
      allow list, update, delete: if false;
    }

    // ── weekly_stats ───────────────────────────────────────────────────────
    // Written only by Cloud Functions (Admin SDK bypasses rules).
    // Anyone can read aggregated stats (no PII here).
    match /weekly_stats/{weekKey} {
      allow read: if true;
      allow write: if false; // only Admin SDK (Cloud Functions)
    }

    // ── fcm_tokens ─────────────────────────────────────────────────────────
    // Users can create/delete their own token (doc ID = the token itself).
    // No reads allowed — prevents harvesting notification tokens.
    match /fcm_tokens/{tokenId} {
      allow create: if
        request.auth != null &&
        request.resource.data.token == tokenId &&
        request.resource.data.keys().hasAll(['token', 'subscribedAt']);

      allow delete: if request.auth != null;

      allow read, update: if false;
    }
  }
}
